# Copy to .env.deploy and fill in (never commit .env.deploy)

AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=123456789012
ECR_REGISTRY=123456789012.dkr.ecr.ap-south-1.amazonaws.com

# --- Secrets (used by setup-secrets.ps1) ---
OPENAI_API_KEY=sk-your-key-here
SECRET_KEY=change-me-to-a-long-random-string
POSTGRES_USER=ragwebui
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DATABASE=ragwebui
POSTGRES_SCHEMA=rag_private

# --- RDS (after setup-rds.ps1) ---
RDS_ENDPOINT=rag-postgres.xxxxx.ap-south-1.rds.amazonaws.com
RDS_INSTANCE_ID=rag-postgres
RDS_SUBNET_GROUP=your-db-subnet-group
RDS_SECURITY_GROUP_ID=sg-xxxxxxxx

# --- S3 uploads (after setup-s3.ps1) ---
S3_UPLOAD_BUCKET=rag-uploads-123456789012-ap-south-1

# --- ALB + Fargate (setup-alb-fargate.ps1 fills ALB_* and FARGATE_SECURITY_GROUP_ID) ---
VPC_ID=vpc-xxxxxxxx
ALB_SUBNET_IDS=subnet-aaa,subnet-bbb
# ALB_ARN=
# ALB_TARGET_GROUP_ARN=
# FARGATE_SECURITY_GROUP_ID=

# --- HTTPS (optional — add when company domain + ACM cert ready) ---
# ACM_CERT_ARN=arn:aws:acm:ap-south-1:123456789012:certificate/xxxxxxxx
# DOMAIN_NAME=rag.example.com

EC2_INSTANCE_ID=i-xxxxxxxx
